# Supabase — Settings > API no dashboard
NEXT_PUBLIC_SUPABASE_URL=               # Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Publishable key (anon/public) — safe for client
SUPABASE_SERVICE_ROLE_KEY=              # Secret key (service_role) — server-only, NEVER expose to client

# Claude — usa OAuth token da sua conta Max automaticamente
# Requer Claude Code CLI autenticado (token em ~/.claude/.credentials.json)

# Serper.dev — Google Search API (2500 buscas grátis)
# Cadastro: https://serper.dev
SERPER_API_KEY=

# LinkedIn Credentials Encryption
LINKEDIN_ENCRYPTION_KEY=                # Gere com: openssl rand -hex 32

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
